generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                 Int            @id @default(autoincrement())
  clerkId            String         @unique @map("clerk_id")
  email              String         @unique
  name               String?
  subscriptionTier   String         @default("free") @map("subscription_tier")
  subscriptionStatus String         @default("active") @map("subscription_status")
  createdAt          DateTime       @default(now()) @map("created_at")
  updatedAt          DateTime       @updatedAt @map("updated_at")

  apis               Api[]
  monthlyUsages      MonthlyUsage[]
  payments           Payment[]
  egldTransactions   EgldTransaction[]
  apiRequests        ApiRequest[]

  @@map("users")
}

model Api {
  id              Int       @id @default(autoincrement())
  userId          Int       @map("user_id")
  apiKey          String    @unique @map("api_key")
  apiName         String    @map("api_name")
  sheetId         String    @map("sheet_id")
  sheetUrl        String    @map("sheet_url")
  sheetName       String    @default("Sheet1") @map("sheet_name")
  isActive        Boolean   @default(true) @map("is_active")
  callCountTotal  Int       @default(0) @map("call_count_total")
  callCountMonth  Int       @default(0) @map("call_count_month")
  lastAccessed    DateTime? @map("last_accessed")
  createdAt       DateTime  @default(now()) @map("created_at")

  user            User      @relation(fields: [userId], references: [id])
  apiCalls        ApiCall[]

  @@index([userId])
  @@index([apiKey])
  @@map("apis")
}

model ApiCall {
  id             Int      @id @default(autoincrement())
  apiId          Int      @map("api_id")
  apiKey         String   @map("api_key")
  endpoint       String
  statusCode     Int      @map("status_code")
  responseTimeMs Int?     @map("response_time_ms")
  ipAddress      String?  @map("ip_address")
  cacheHit       Boolean  @default(false) @map("cache_hit")
  timestamp      DateTime @default(now())

  api            Api      @relation(fields: [apiId], references: [id])

  @@index([apiId])
  @@index([timestamp])
  @@map("api_calls")
}

model MonthlyUsage {
  id         Int      @id @default(autoincrement())
  userId     Int      @map("user_id")
  month      DateTime
  callsUsed  Int      @default(0) @map("calls_used")
  callsLimit Int      @default(1000) @map("calls_limit")

  user       User     @relation(fields: [userId], references: [id])

  @@unique([userId, month], name: "userId_month")
  @@index([userId])
  @@map("monthly_usages")
}

model Payment {
  id               String    @id @default(cuid())
  userId           Int?      @map("user_id")
  amount           String
  recipientAddress String    @map("recipient_address")
  userAddress      String    @map("user_address")
  txHash           String?   @unique @map("tx_hash")
  status           String    @default("pending")
  tier             String?
  createdAt        DateTime  @default(now()) @map("created_at")
  confirmedAt      DateTime? @map("confirmed_at")

  user             User?     @relation(fields: [userId], references: [id])

  @@index([userAddress])
  @@map("payments")
}

model EgldTransaction {
  id           Int       @id @default(autoincrement())
  userId       Int       @map("user_id")
  txHash       String    @unique @map("tx_hash")
  amountEgld   Float     @map("amount_egld")
  creditsAdded Float     @map("credits_added")
  status       String    @default("pending")
  confirmedAt  DateTime? @map("confirmed_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  user         User      @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("egld_transactions")
}

model ApiRequest {
  id        Int      @id @default(autoincrement())
  userId    Int?     @map("user_id")
  sheetId   String   @map("sheet_id")
  method    String
  endpoint  String
  status    Int
  createdAt DateTime @default(now()) @map("created_at")

  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([sheetId])
  @@map("api_requests")
}
