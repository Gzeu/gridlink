# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://user:password@localhost:5432/gridlink"

# ── Redis (Upstash — free tier works for Vercel serverless) ─────────────────
UPSTASH_REDIS_REST_URL="https://your-instance.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ── Google Service Account ───────────────────────────────────────────────────
# Do NOT use GOOGLE_CREDENTIALS_PATH (no filesystem on Vercel).
# Instead, paste the service account credentials inline as env vars.
GOOGLE_CLIENT_EMAIL="gridlink@your-project.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEv...\n-----END PRIVATE KEY-----\n"

# ── MultiversX ───────────────────────────────────────────────────────────────
# Mainnet: https://api.multiversx.com / chain ID: 1
# Devnet:  https://devnet-api.multiversx.com / chain ID: D
NEXT_PUBLIC_EGLD_API_URL="https://api.multiversx.com"
NEXT_PUBLIC_EGLD_CHAIN_ID="1"
# Your wallet address — users send EGLD here to unlock paid tiers
EGLD_RECEIVER_ADDRESS="erd1..."

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://gridlink.vercel.app"

# ── Auth (NextAuth or Clerk) ─────────────────────────────────────────────────
NEXTAUTH_SECRET="generate-with: openssl rand -base64 32"
NEXTAUTH_URL="http://localhost:3000"
